# Backend (server) environment
# Put your Gemini API key here (do NOT commit .env to git)
GEMINI_API_KEY=

# Backend port (frontend proxies /api to this)
PORT=5000

# Frontend (Vite) environment
# WARNING: Any VITE_* var is exposed to the browser at build time.
# Only set this if you intentionally want browser-side Gemini features (e.g. STT/realtime)
# VITE_GEMINI_API_KEY=
